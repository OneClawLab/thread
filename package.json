{
  "name": "thread",
  "type": "module",
  "version": "1.0.0",
  "description": "thread is a CLI tool for managing event queues backed by SQLite.",
  "bin": {
    "thread": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:run": "vitest run",
    "release:local": "npm run build && npm link"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.4.0",
    "fast-check": "^4.6.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
